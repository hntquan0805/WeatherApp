{
  "ConnectionStrings": {
    "DefaultConnection": "%WEATHERAPP_DB_CONNECTION%"
  },
  "JwtSettings": {
    "SecretKey":        "%WEATHERAPP_JWT_SECRETKEY%",
    "Issuer":           "%WEATHERAPP_JWT_ISSUER%",
    "Audience":         "%WEATHERAPP_JWT_AUDIENCE%",
    "ExpiryInMinutes":  "%WEATHERAPP_JWT_EXPIRYINMINUTES%"
  },
  "OpenWeatherMap": {
    "ApiKey":   "%WEATHERAPP_OWM_APIKEY%",
    "BaseUrl":  "%WEATHERAPP_OWM_BASEURL%"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}